{
    "name": "cmixin/business-day",
    "description": "Carbon mixin to handle business days",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "nesbot/carbon": "^3.11.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.63",
        "phpstan/phpstan": "^2.1.40",
        "phpstan/extension-installer": "*"
    },
    "autoload": {
        "psr-4": {
            "Cmixin\\": "src/Cmixin/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "license": "MIT",
    "authors": [
        {
            "name": "KyleKatarn",
            "email": "carbon@selfbuild.fr"
        }
    ],
    "minimum-stability": "dev",
    "scripts": {
        "types": "php types.php"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Cmixin\\BusinessDay\\Laravel\\ServiceProvider"
            ]
        },
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
